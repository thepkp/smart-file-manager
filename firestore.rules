rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }
    function isValidMaterial(data) {
      return data.keys().hasAll(['uid', 'title', 'type', 'createdAt', 'content', 'subject', 'semester', 'status', 'priority']) &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.type in ['assignment', 'tutorial', 'link', 'pyq', 'note'] &&
             data.content is string && data.content.size() < 1048576 && // 1MB limit
             data.subject is string && data.subject.size() < 100 &&
             data.semester is string && data.semester.size() < 100 &&
             data.status in ['pending', 'completed', 'none'] &&
             data.priority in ['high', 'medium', 'low', 'none'] &&
             data.createdAt is timestamp &&
             (!('dueDate' in data) || data.dueDate is timestamp || data.dueDate == null) &&
             (!('isPublic' in data) || data.isPublic is bool) &&
             (!('aiSummary' in data) || (data.aiSummary is string && data.aiSummary.size() < 2000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /materials/{materialId} {
      allow read: if isDocOwner() || (resource != null && resource.data.isPublic == true);
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid && 
                      isValidMaterial(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.uid == resource.data.uid &&
                      isValidMaterial(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
